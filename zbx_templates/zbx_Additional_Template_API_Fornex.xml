                <item>
                    <name>Fornex order days to expire</name>
                    <type>DEPENDENT</type>
                    <key>fornex.order.days.to.expire</key>
                    <delay>0</delay>
                    <value_type>FLOAT</value_type>
                    <applications>
                        <application>
                            <name>Fornex</name>
                        </application>
                    </applications>
                    <preprocessing>
                        <step>
                            <type>JSONPATH</type>
                            <params>$..expiration_date</params>
                        </step>
                        <step>
                            <type>JAVASCRIPT</type>
                            <params>var expirationDate = value.substring(value.lastIndexOf(&quot;[&quot;) + 2, value.lastIndexOf(&quot;+&quot;));
var expirationTime = new Date(expirationDate).getTime();
var currentTime = new Date().getTime();
var days = Math.floor((expirationTime - currentTime) / 86400000);
return days;</params>
                        </step>
                    </preprocessing>
                    <master_item>
                        <key>fornex.orders.list</key>
                    </master_item>
                    <triggers>
                        <trigger>
                            <expression>{last()}&lt;=0</expression>
                            <recovery_mode>RECOVERY_EXPRESSION</recovery_mode>
                            <recovery_expression>{last()}&gt;0</recovery_expression>
                            <name>Fornex order expired</name>
                            <priority>DISASTER</priority>
                        </trigger>
                        <trigger>
                            <expression>{last()}&lt;=7</expression>
                            <recovery_mode>RECOVERY_EXPRESSION</recovery_mode>
                            <recovery_expression>{last()}&gt;7</recovery_expression>
                            <name>Fornex order expires in {ITEM.LASTVALUE} days</name>
                            <priority>HIGH</priority>
                            <dependencies>
                                <dependency>
                                    <name>Fornex order expired</name>
                                    <expression>{Additional Template API Fornex:fornex.order.days.to.expire.last()}&lt;=0</expression>
                                    <recovery_expression>{Additional Template API Fornex:fornex.order.days.to.expire.last()}&gt;0</recovery_expression>
                                </dependency>
                            </dependencies>
                        </trigger>
                        <trigger>
                            <expression>{last()}&lt;=14</expression>
                            <recovery_mode>RECOVERY_EXPRESSION</recovery_mode>
                            <recovery_expression>{last()}&gt;14</recovery_expression>
                            <name>Fornex order expires in {ITEM.LASTVALUE} days</name>
                            <priority>AVERAGE</priority>
                            <dependencies>
                                <dependency>
                                    <name>Fornex order expires in {ITEM.LASTVALUE} days</name>
                                    <expression>{Additional Template API Fornex:fornex.order.days.to.expire.last()}&lt;=7</expression>
                                    <recovery_expression>{Additional Template API Fornex:fornex.order.days.to.expire.last()}&gt;7</recovery_expression>
                                </dependency>
                            </dependencies>
                        </trigger>
                        <trigger>
                            <expression>{last()}&lt;=30</expression>
                            <recovery_mode>RECOVERY_EXPRESSION</recovery_mode>
                            <recovery_expression>{last()}&gt;30</recovery_expression>
                            <name>Fornex order expires in {ITEM.LASTVALUE} days</name>
                            <priority>WARNING</priority>
                            <dependencies>
                                <dependency>
                                    <name>Fornex order expires in {ITEM.LASTVALUE} days</name>
