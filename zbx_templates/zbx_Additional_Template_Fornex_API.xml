                    <preprocessing>
                        <step>
                            <type>JAVASCRIPT</type>
                            <params>var s = value.substring(value.lastIndexOf(&quot;[&quot;) +2, value.lastIndexOf(&quot;+&quot;));
var d = new Date(s);
return d / 1000;</params>
